# User Namespace
# Unique per-user identifier used as a PREFIX for shared resource names
# (blob containers, search index, Cosmos containers, ACR repos, container apps, etc.)
# Use lowercase letters and digits only (no spaces, underscores, or special characters).
USERNAME=

# Azure Storage
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_STORAGE_CONNECTION_STRING=

# Monitoring and Search
LOG_ANALYTICS_WORKSPACE_NAME=
SEARCH_SERVICE_NAME=
SEARCH_SERVICE_ENDPOINT=
SEARCH_ADMIN_KEY=

# AI Foundry
AI_FOUNDRY_HUB_NAME=
# Per-user project name, prefixed with your USERNAME namespace (e.g. punits-proj)
AI_FOUNDRY_PROJECT_NAME="proj-${USERNAME}-"
AI_FOUNDRY_ENDPOINT=
AI_FOUNDRY_KEY=
AI_FOUNDRY_HUB_ENDPOINT=
# Project endpoint ends with the project name above
AI_FOUNDRY_PROJECT_ENDPOINT="https://<foundry-account>.services.ai.azure.com/api/projects/${AI_FOUNDRY_PROJECT_NAME}"
AZURE_AI_CONNECTION_ID=

# Azure Cosmos DB
COSMOS_ENDPOINT=
COSMOS_KEY=
COSMOS_CONNECTION_STRING=

# Azure OpenAI compatibility variables
AZURE_OPENAI_SERVICE_NAME=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=
AZURE_OPENAI_API_VERSION=
MODEL_DEPLOYMENT_NAME=

# Mistral Document AI deployment
MISTRAL_DOCUMENT_AI_DEPLOYMENT_NAME=
MISTRAL_DOCUMENT_AI_ENDPOINT=
MISTRAL_DOCUMENT_AI_KEY=

# Document Intelligence
DOCUMENT_INTELLIGENCE_ENDPOINT=
DOCUMENT_INTELLIGENCE_KEY=

# Container Apps and resource group
CONTAINER_APP_ENVIRONMENT_NAME=
AZURE_RESOURCE_GROUP=

# API Management
API_MANAGEMENT_NAME=
API_MANAGEMENT_GATEWAY_URL=

# Container Registry
ACR_NAME=
AZURE_CONTAINER_REGISTRY_NAME=
ACR_USERNAME=
ACR_PASSWORD=
